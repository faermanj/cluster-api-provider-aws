{
    "name": "Cluster API / AWS / KIND Codespace",
    "build": {
      "dockerfile": "Containerfile"
    },
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-kubernetes-tools.vscode-kubernetes-tools",
          "ms-azuretools.vscode-docker"
        ]
      }
    },
    "postCreateCommand": "curl https://raw.githubusercontent.com/faermanj/cluster-api-provider-aws/add-dedicated-hosts/.devcontainer/postAttachCommand.sh | bash",
    "forwardPorts": [22, 6443, 8080],
    "remoteUser": "vscode"
  }
  